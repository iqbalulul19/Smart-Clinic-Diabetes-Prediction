<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            stylesheets="@style.css"
            styleClass="root-dashboard">

    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
            <VBox fx:id="sidebar" spacing="5" alignment="TOP_CENTER" prefWidth="240" styleClass="sidebar">
                <Button text="☰" onAction="#toggleSidebar" styleClass="toggle-btn"/>
                <Label fx:id="logoTitle" text="PREDIKSI" styleClass="logo-title"/>
                <Separator prefWidth="180"/>

                <Button fx:id="btnDashboard" text="🏠  Dashboard" styleClass="menu-btn"/>
                <Button fx:id="btnPasien" text="👨‍⚕  Pasien" styleClass="menu-btn" onAction="#openPasien"/>
                
                <Button fx:id="btnPrediksi" text="🧠  Prediksi Diabetes" styleClass="menu-btn" onAction="#openPrediksi"/>
                        
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪 Logout" styleClass="logout-btn"/>
            </VBox>
        </ScrollPane>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <VBox spacing="5">
                <Label text="Dashboard" styleClass="dashboard-title"/>
                <Label text="Selamat Datang di Prediksi Diabetes" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField promptText="Cari data pasien..." prefWidth="250" styleClass="search-box"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="25">
            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <HBox spacing="20">
                <VBox spacing="10" prefWidth="250" prefHeight="120" styleClass="card-blue">
                    <Label text="👨‍⚕ Total Pasien" styleClass="card-title"/>
                    
                    <Label fx:id="lblTotalPasien" text="0" styleClass="card-value"/>
                </VBox>

                <VBox spacing="10" prefWidth="250" prefHeight="120" styleClass="card-orange">
                    <Label text="🧠 Prediksi" styleClass="card-title"/>
                    <Label text="532" styleClass="card-value"/>
                </VBox>
            </HBox>

            <VBox spacing="15" styleClass="table-container">
                <Label text="Data Pasien Terbaru" styleClass="section-title"/>
                <TableView fx:id="tableDashboard" prefHeight="500">
                    <columns>
                        <TableColumn text="ID" prefWidth="80"/>
                        <TableColumn text="Nama" prefWidth="220"/>
                        <TableColumn text="Umur" prefWidth="120"/>
                        <TableColumn text="Gender" prefWidth="180"/>
                        <TableColumn text="Alamat" prefWidth="300"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

</BorderPane>