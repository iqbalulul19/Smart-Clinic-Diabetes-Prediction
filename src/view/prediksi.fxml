<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PrediksiController" stylesheets="@style.css">
    
    <top>
        <VBox alignment="CENTER" spacing="10" styleClass="top-panel">
            <padding>
                <Insets top="20" bottom="20"/>
            </padding>
            <Label text="PREDIKSI DIABETES" styleClass="title">
                <font>
                    <Font size="28"/>
                </font>
            </Label>
            <Label text="Prediksi Risiko Diabetes Sederhana (Rule-Based)"/>
        </VBox>
    </top>
    
    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="20" styleClass="main-panel">
                
                <GridPane alignment="CENTER" hgap="15" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="150"/>
                        <ColumnConstraints minWidth="300"/>
                    </columnConstraints>
                    
                    <Label text="Pilih Pasien" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <ComboBox fx:id="cbPasien" prefWidth="300" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
                    <Label text="Pregnancies" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtPregnancies" promptText="Jumlah Kehamilan" prefWidth="300" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    
                    <Label text="Glucose (Gula)" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtGlucose" promptText="Kadar Glukosa" prefWidth="300" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    
                    <Label text="Blood Pressure" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtBloodPressure" promptText="Tekanan Darah" prefWidth="300" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    
                    <Label text="Skin Thickness" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtSkinThickness" promptText="Ketebalan Kulit" prefWidth="300" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    
                    <Label text="Insulin" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtInsulin" promptText="Kadar Insulin" prefWidth="300" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                    
                    <Label text="BMI" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtBMI" promptText="Body Mass Index" prefWidth="300" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                    
                    <Label text="Pedigree Function" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtPedigree" promptText="Diabetes Pedigree Function" prefWidth="300" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                    
                    <Label text="Age (Umur)" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtAge" promptText="Usia" prefWidth="300" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                </GridPane>
                
                <Button text="🔍 Prediksi" prefWidth="200" prefHeight="40" onAction="#handlePrediksi" styleClass="btn-save"/>
                
                <Label text="HASIL PREDIKSI" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblHasil" text="Belum ada prediksi" style="-fx-font-size: 14px;"/>
                
            </VBox>
        </StackPane>
    </center>
</BorderPane>